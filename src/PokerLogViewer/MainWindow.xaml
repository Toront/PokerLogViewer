<Window x:Class="PokerLogViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PokerLogViewer.Converters"
        mc:Ignorable="d"
        Title="PokerLogViewer"
        Height="780"
        Width="1280"
        MinHeight="600"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,8">
            <Button Content="Select Folder"
                    Command="{Binding SelectFolderCommand}"
                    Width="120"
                    Height="30"
                    DockPanel.Dock="Left"
                    Margin="0,0,8,0"/>

            <Border BorderBrush="#C8C8C8"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8,4"
                    Background="#FAFAFA">
                <TextBlock Text="{Binding SelectedFolderPath}"
                           TextWrapping="Wrap"
                           Foreground="#444"/>
            </Border>
        </DockPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,8">
            <Button Content="Start Scan"
                    Command="{Binding StartScanCommand}"
                    Width="120"
                    Height="30"/>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{Binding TableSearchText, UpdateSourceTrigger=PropertyChanged}"
                     Height="28"
                     Margin="0,0,8,0"
                     ToolTip="Search tables by TableName"
                     VerticalContentAlignment="Center"/>

            <TextBox Grid.Column="1"
                     Text="{Binding HandSearchText, UpdateSourceTrigger=PropertyChanged}"
                     Height="28"
                     Margin="0,0,8,0"
                     ToolTip="Search hands by HandID"
                     VerticalContentAlignment="Center"/>

            <TextBlock Grid.Column="2"
                       Text="Search is applied instantly as you type."
                       Foreground="#777"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"/>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Tables" Grid.Column="0">
                <Grid>
                    <ListBox ItemsSource="{Binding TablesView}"
                             SelectedItem="{Binding SelectedTable, Mode=TwoWay}"
                             DisplayMemberPath="TableName"
                             BorderThickness="0"
                             Background="Transparent"
                             Visibility="{Binding HasTables, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <TextBlock Text="No tables loaded. Please start a scan."
                               Foreground="#888"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="12"
                               Visibility="{Binding HasTables, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="Hands" Grid.Column="1">
                <Grid>
                    <ListBox ItemsSource="{Binding HandsView}"
                             SelectedItem="{Binding SelectedHand, Mode=TwoWay}"
                             BorderThickness="0"
                             Background="Transparent"
                             Visibility="{Binding HasHands, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding HandID}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Text="Select a table to see hands."
                               Foreground="#888"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="12"
                               Visibility="{Binding HasHands, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="Hand Details" Grid.Column="2" Margin="0">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasSelectedHand, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Margin="8">
                            <TextBlock Text="{Binding SelectedHand.HandID, StringFormat=Hand ID: {0}}"
                                       Margin="0,0,0,6"/>

                            <TextBlock Text="{Binding SelectedHand.TableName, StringFormat=Table: {0}}"
                                       Margin="0,0,0,6"/>

                            <TextBlock Text="{Binding SelectedHand.WinAmount, StringFormat=Win Amount: {0}}"
                                       Margin="0,0,0,6"/>

                            <TextBlock Text="Players:"
                                       FontWeight="Bold"
                                       Margin="0,12,0,4"/>

                            <ItemsControl ItemsSource="{Binding SelectedHand.Players}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Margin="0,0,0,4"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Winners:"
                                       FontWeight="Bold"
                                       Margin="0,12,0,4"/>

                            <ItemsControl ItemsSource="{Binding SelectedHand.Winners}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Margin="0,0,0,4"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <TextBlock Text="Select a hand to see details."
                               Foreground="#888"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="12"
                               Visibility="{Binding HasSelectedHand, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                </Grid>
            </GroupBox>
        </Grid>

        <Border Grid.Row="4"
                Margin="0,8,0,0"
                Padding="8"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="4"
                Background="#F8F8F8">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="#333"/>
        </Border>
    </Grid>
</Window>